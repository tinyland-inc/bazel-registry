"""
scheduling-kit - Bazel Module Configuration

Backend-agnostic scheduling library with pluggable adapters, payment processors,
and Svelte UI components. Published as @tummycrypt/scheduling-kit on npm.

Bzlmod-native configuration for Bazel 8+.
CI and publishing remain pnpm-driven today; Bazel targets are the hermetic build graph.

Build targets:
  bazel build //:scheduling_kit       # Svelte package build (dist/)
  bazel build //:pkg                  # npm-publishable package
  bazel test //:test                  # Unit tests (vitest)
  bazel build //:typecheck            # Type validation (svelte-check)

Subpackage targets (finer-grained caching):
  bazel build //src/core:core         # Types, adapter interface, Effect wrappers
  bazel build //src/adapters:adapters # HomegrownAdapter (PostgreSQL/Drizzle)
  bazel build //src/payments:payments # Stripe, Venmo, manual adapters
  bazel build //src/components:components  # Svelte checkout UI
"""

module(
    name = "tummycrypt_scheduling_kit",
    version = "0.7.5",
    compatibility_level = 1,
)

# =============================================================================
# Core Bazel dependencies
# =============================================================================

bazel_dep(name = "bazel_skylib", version = "1.8.2")
bazel_dep(name = "platforms", version = "1.0.0")
bazel_dep(name = "aspect_bazel_lib", version = "2.22.5")

# =============================================================================
# JavaScript / TypeScript toolchain (Aspect Build)
# =============================================================================

bazel_dep(name = "rules_nodejs", version = "6.7.3")
bazel_dep(name = "aspect_rules_js", version = "2.9.1")
bazel_dep(name = "aspect_rules_ts", version = "3.8.4")
bazel_dep(name = "aspect_rules_swc", version = "2.6.1")

# =============================================================================
# Inter-module dependencies (tinyland building blocks)
# =============================================================================

# HomegrownAdapter uses @tummycrypt/tinyland-auth-pg's drizzle schema and
# storage primitives. The bazel_dep edge mirrors the npm dependency.
bazel_dep(name = "tummycrypt_tinyland_auth_pg", version = "0.2.2")

# =============================================================================
# Node.js toolchain
# =============================================================================

node = use_extension("@rules_nodejs//nodejs:extensions.bzl", "node")
node.toolchain(node_version = "22.13.1")

# =============================================================================
# pnpm toolchain
# =============================================================================

pnpm = use_extension("@aspect_rules_js//npm:extensions.bzl", "pnpm")
pnpm.pnpm(
    name = "pnpm",
    pnpm_version = "9.15.9",
)
use_repo(pnpm, "pnpm")

# =============================================================================
# npm dependency resolution from pnpm-lock.yaml
# =============================================================================

npm = use_extension("@aspect_rules_js//npm:extensions.bzl", "npm")

npm.npm_translate_lock(
    name = "tummycrypt_scheduling_kit_npm",
    pnpm_lock = "//:pnpm-lock.yaml",
    data = ["//:package.json"],
    npmrc = "//:.npmrc",
)

use_repo(npm, "tummycrypt_scheduling_kit_npm")

# =============================================================================
# TypeScript toolchain
# =============================================================================

rules_ts_ext = use_extension("@aspect_rules_ts//ts:extensions.bzl", "ext")

rules_ts_ext.deps(
    ts_version = "5.9.3",
)

use_repo(rules_ts_ext, "npm_typescript")

# =============================================================================
# SWC toolchain (fast transpilation)
# =============================================================================

swc = use_extension("@aspect_rules_swc//swc:extensions.bzl", "swc")
swc.toolchain(
    name = "swc",
    swc_version = "v1.10.12",
)
use_repo(swc, "swc_toolchains")

register_toolchains("@swc_toolchains//:all")
